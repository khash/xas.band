---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { tracks, cover } from '../data/tracks';

const listen = [
  { name: 'SoundCloud' },
  { name: 'Spotify' },
  { name: 'Apple Music' },
  { name: 'YouTube' },
  { name: 'Bandcamp' },
];
---

<Layout>
  <main class="grain min-h-dvh overflow-x-hidden bg-neutral-950 font-sans text-neutral-200 selection:bg-fuchsia-500/30">
    <div class="pointer-events-none fixed inset-0 -z-10">
      <div class="absolute -top-40 left-1/2 size-[42rem] -translate-x-1/2 rounded-full bg-fuchsia-600/20 blur-[120px]"></div>
      <div class="absolute top-1/3 -left-40 size-[34rem] rounded-full bg-violet-700/20 blur-[120px]"></div>
      <div class="absolute bottom-0 right-0 size-[36rem] rounded-full bg-cyan-500/10 blur-[120px]"></div>
      <div class="grain-overlay absolute inset-0 opacity-[0.06] mix-blend-screen"></div>
    </div>

    <!-- Nav -->
    <header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6">
      <a href="#" class="font-display text-2xl tracking-tight text-white [text-shadow:0_0_24px_rgb(217_70_239/0.55)]">XAS</a>
      <nav class="hidden items-center gap-8 font-mono text-xs uppercase tracking-wide text-neutral-400 md:flex">
        <a href="#music" class="hover:text-white">Music</a>
        <a href="#voice" class="hover:text-white">The Voice</a>
        <a href="#story" class="hover:text-white">Story</a>
      </nav>
      <a href="#music" class="rounded-full bg-white/10 px-5 py-2 text-sm font-medium text-white ring-1 ring-white/15 backdrop-blur hover:bg-white/15">The music</a>
    </header>

    <!-- Hero -->
    <section class="relative mx-auto grid max-w-6xl items-center gap-10 px-6 pt-10 pb-16 lg:grid-cols-[1.1fr_0.9fr] lg:pt-20">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-white/5 py-1.5 pl-2.5 pr-4 font-mono text-xs uppercase tracking-wide text-fuchsia-200 ring-1 ring-fuchsia-400/30">
          <span class="relative grid size-2 place-items-center">
            <span class="absolute size-2 animate-ping rounded-full bg-fuchsia-400/70"></span>
            <span class="size-1.5 rounded-full bg-fuchsia-400"></span>
          </span>
          Debut album · coming soon
        </span>
        <p class="mt-6 font-mono text-xs uppercase tracking-wide text-fuchsia-300/80">Composer · music creator</p>
        <h1 class="mt-5 font-display text-6xl text-white sm:text-7xl lg:text-8xl">
          Satellite hearts<br />in the night
        </h1>
        <p class="mt-6 max-w-[52ch] text-pretty text-lg text-neutral-300">
          Xas builds cinematic electronica at the seam of human feeling and machine craft — synth motifs that return like half-remembered dreams, and the intimate voice of Solène.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href="#music"
            class="inline-flex items-center gap-3 rounded-full bg-linear-to-r from-fuchsia-500 via-violet-500 to-cyan-400 px-6 py-3 text-sm font-semibold text-neutral-950 shadow-[0_0_40px_-8px_rgb(217_70_239/0.7)] hover:brightness-110">
            Explore the singles
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-4"><path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </a>
          <a href="#story" class="text-sm font-medium text-neutral-300 underline-offset-4 hover:text-white hover:underline">The story →</a>
        </div>
      </div>

      <div class="relative">
        <div class="animate-drift relative mx-auto w-72 sm:w-80">
          <Image src={cover('neon-noir')} alt="" width={640} height={640} format="webp" quality={80} class="aspect-square w-full rounded-2xl object-cover shadow-2xl shadow-fuchsia-900/40 outline-1 -outline-offset-1 outline-white/10" />
          <Image src={cover('here-and-now')} alt="" width={400} height={400} format="webp" quality={80} class="absolute -bottom-10 -left-12 w-40 rotate-[-6deg] rounded-xl object-cover shadow-2xl outline-1 -outline-offset-1 outline-white/10 sm:w-48" />
        </div>
        <div class="absolute -bottom-16 left-1/2 h-24 w-64 -translate-x-1/2 bg-linear-to-b from-fuchsia-500/20 to-transparent blur-2xl"></div>
      </div>
    </section>

    <!-- Lyric ticker -->
    <div class="overflow-hidden border-y border-white/5 py-4">
      <div class="flex w-max animate-marquee gap-8 font-display text-2xl text-white/15">
        {Array.from({ length: 2 }).map(() => (
          <span class="flex shrink-0 items-center gap-8">
            <span>EVERY NOTE REMEMBERS SOMETHING</span><span class="text-fuchsia-400/40">✸</span>
            <span>ONLY NOW, ONLY THIS MOMENT MOVING</span><span class="text-cyan-400/40">✸</span>
            <span>WE ARE BREATHING THROUGH THE STATIC AND THE LIGHT</span><span class="text-fuchsia-400/40">✸</span>
          </span>
        ))}
      </div>
    </div>

    <!-- Music -->
    <section id="music" class="mx-auto max-w-6xl px-6 py-20">
      <div class="flex items-end justify-between">
        <h2 class="font-display text-4xl text-white sm:text-5xl">Singles</h2>
        <p class="font-mono text-xs uppercase tracking-wide text-neutral-500">7 singles · 2024–2025</p>
      </div>
      <ul role="list" class="mt-8 divide-y divide-white/5">
        {tracks.map((t) => (
          <li>
            <a
              href={t.lyrics ? `/music/${t.slug}` : undefined}
              class={`group grid grid-cols-[auto_1fr_auto] items-center gap-4 py-4 ${t.lyrics ? 'cursor-pointer' : ''}`}
            >
              <span class="size-12 shrink-0 overflow-hidden rounded-lg sm:size-14">
                <Image src={cover(t.slug)} alt="" width={160} height={160} format="webp" quality={80} class="size-full object-cover transition group-hover:scale-105" />
              </span>
              <span class="min-w-0">
                <span class="block truncate text-base font-medium text-neutral-100 group-hover:text-white">{t.title}</span>
                <span class="block truncate font-mono text-xs text-neutral-500">{t.note}</span>
              </span>
              <span class="flex items-center gap-3 font-mono text-sm tabular-nums text-neutral-500">
                {t.lyrics && <span class="hidden text-xs uppercase tracking-wide text-fuchsia-300/70 group-hover:inline">Lyrics →</span>}
                {t.dur}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Voice / Solène -->
    <section id="voice" class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div class="relative">
          <img src="/img/solene-avatar.png" alt="Solène" class="aspect-4/5 w-full rounded-2xl object-cover object-top outline-1 -outline-offset-1 outline-white/10" />
          <div class="absolute inset-0 rounded-2xl bg-linear-to-t from-fuchsia-900/40 via-transparent to-transparent mix-blend-color"></div>
        </div>
        <div>
          <p class="font-mono text-xs uppercase tracking-wide text-cyan-300/80">The voice</p>
          <h2 class="mt-4 font-display text-4xl text-white sm:text-5xl">Solène</h2>
          <p class="mt-5 text-pretty text-lg text-neutral-300">
            Close-mic and fragile, Solène carries every Xas record — a human signal threaded through machine textures. She doesn’t belt; she remembers. The result is intimacy you can dance to.
          </p>
          <blockquote class="mt-8 border-l-2 border-fuchsia-500/60 pl-5 font-display text-2xl text-white/90">
            “The hardest part was knowing that I already had.”
          </blockquote>
        </div>
      </div>
    </section>

    <!-- Story -->
    <section id="story" class="mx-auto max-w-6xl px-6 py-20">
      <div class="grid gap-10 lg:grid-cols-2">
        <h2 class="font-display text-4xl text-white sm:text-6xl">Human<span class="text-fuchsia-400"> × </span>technology</h2>
        <div class="space-y-5 text-pretty text-lg text-neutral-300">
          <p>Xas is a composer and music creator. Each release is an experiment in memory — built from recurring synth motifs, organic percussion and the spoken philosophy of presence.</p>
          <p>Machines extend the hand; they don’t replace it. What stays is a life: nostalgic, restless, and fully here.</p>
        </div>
      </div>
      <div class="mt-10">
        <img src="/img/studio-1.jpg" alt="Xas at the mixing console with Solène in the vocal booth" class="aspect-video w-full rounded-xl object-cover object-[center_33%] outline-1 -outline-offset-1 outline-white/10" />
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-white/5">
      <div class="mx-auto flex max-w-6xl flex-col items-center gap-5 px-6 py-16 text-center">
        <p class="font-mono text-xs uppercase tracking-wide text-fuchsia-300/80">Coming soon</p>
        <p class="max-w-[24ch] text-balance font-display text-3xl text-white sm:text-4xl">New music from Xas, with Solène</p>
        <p class="max-w-[46ch] text-pretty text-neutral-400">Releasing on all platforms soon. Follow to hear it first.</p>
        <ul role="list" class="mt-2 flex flex-wrap justify-center gap-3">
          {listen.map((l) => (
            <li><span class="inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-medium text-neutral-500 ring-1 ring-white/10">
              <span class="size-1.5 rounded-full bg-fuchsia-400/60"></span>{l.name}
            </span></li>
          ))}
        </ul>
        <nav class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-mono text-xs uppercase tracking-wide text-neutral-500">
          <a href="/terms" class="hover:text-white">Terms</a>
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="mailto:kash@xas.band" class="hover:text-white">Contact</a>
        </nav>
        <p class="mt-6 font-mono text-xs uppercase tracking-wide text-neutral-600">© 2025–2026 Xas — made of memory and signal</p>
        <p class="font-mono text-xs uppercase tracking-wide text-neutral-600">All music &amp; lyrics © 2025–2026 Xas. All rights reserved.</p>
      </div>
    </footer>
  </main>
</Layout>
